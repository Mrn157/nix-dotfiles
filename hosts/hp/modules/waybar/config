{
    "layer": "top",
    "height": 30,
    "spacing": 5,
    // Choose the order of the modules
    "modules-left": [
        "clock"
    ],
    "modules-center": [
      "hyprland/workspaces",
      "niri/workspaces",
      "dwl/tags"
    ],
    "modules-right": [
        "wireplumber",
        "backlight",
        "custom/wl-gammarelay-applet",
        "battery",
        "custom/tray-left-end", 
        "group/sys-tray",
        "custom/notifications",
        "custom/power-left-end", 
        "group/power"

		],
		"hyprland/window": {
			"separate-outputs": true
		},
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate"
    },
    "dwl/tags": {
      "disable-scroll": true,
      "all-outputs": true,
      "on-click": "activate"
    },
    "niri/workspaces": {
	    "format": "{icon}",
	    "format-icons": {
		    // Named workspaces
		    // (you need to configure them in niri)
		    "browser": "ï’ˆ",
		    "discord": "ïژ’",
		    "chat": "<b>ïپµ</b>",

		    // Icons by state
		    // "active": "ï†’",
		    // "default": "ï„‘"
	    },
    "tray": {
      "icon-size": 18,
      "spacing": 12,
    },
   },

    "custom/tray-collapsed": {
      "format": "َ°‡™ ",
      "tooltip": false
    },

    "custom/tray-left-end": {
      "format": " ",
      "tooltip": false
    },

    "group/sys-tray": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 600,
        "transition-left-to-right": false,
      },
      "modules": [
        "custom/tray-collapsed",
        "tray"
      ]
    },
		"custom/pacman": {
			"interval": 3600,
			"return-type": "json",
			"exec": "pacman-updates",
			"exec-if": "exit 0",
			"on-click": "$TERMINAL -e paru; pkill -SIGRTMIN+8 waybar",
			"signal": 8
		},
    "clock": {
        "tooltip-format": "{:%A, %B %d, %Y}",
        "format": "َ°¥”  {:%I:%M %p}",
        "on-click": "niri msg action toggle-overview"
    },
    "custom/notifications": {
      "tooltip": false,
      "format": " {icon}  ",
      "format-icons": {
        "notification": "َ°‚ڑ",
        "none": "ï‚¢",
        "dnd-notification": "ï‡¶",
        "dnd-none": "ï‡·",
        "inhibited-notification": "ïƒ³",
        "inhibited-none": "ï‚¢",
        "dnd-inhibited-notification": "ï‡¶",
        "dnd-inhibited-none": "ï‡·"
      },

      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
    },

    "battery": {
        "states": {
            "warning": 40
        },
        "format": "{icon} {capacity}%",
        "format-icons": [ "َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹" ],
        "format-charging": "َ°‚„",
        "format-warning": "َ°‚ƒ",
				"tooltip-format": "{capacity}% capacity"
    },
    "network": {
        "format-wifi": "َ°¤¨",
        "format-disconnected": "َ°¤­",
				"tooltip-format": "Connected to {essid}",
				"on-click": "hyprctl dispatch exec '[float]' '$TERMINAL -e nmtui'"
    },
    "wireplumber": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}%",
        "format-muted": "َ°–پ",
				"format-icons": {
					"default": ["ï€¦", "ï€§", "ï€¨"]
				},
				"tooltip-format": "{volume}% volume"
		},
    "custom/power": {
        "format": "ï€‘",
        "on-click": "sleep 0.15 && ~/.config/rofi/powermenu/type-2/powermenu.sh "
    },
    "memory": {
        "format": "î؟…  {}%"
    },
    "custom/wl-gammarelay-applet": {
    "format": "ï†† {}",
    "exec": "wl-gammarelay-rs watch {t}",
    "on-click": "wl-gammarelay-applet",
    "on-scroll-up": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n +100",
    "on-scroll-down": "busctl --user -- call rs.wl-gammarelay / rs.wl.gammarelay UpdateTemperature n -100"
    },
    "custom/shutdown": {
      "format": " ï€‘  ",
      "tooltip": false,
      "on-click": "yad  --text='Shutdown your system?' && systemctl poweroff"
    },
    "custom/reboot": {
      "format": " ï€، ",
      "tooltip": false,
      "on-click": "yad --text='Reboot your system?' && systemctl reboot"
    },
    "custom/logout": {
      "format": " ï‚‹ ",
      "tooltip": false,
      "on-click": "yad --text='Logout?' && (niri msg action quit -s || hyprctl dispatch exit)"
    },
    "custom/firmware": {
      "format": " ï’¼ ",
      "tooltip": false,
      "on-click": "yad --text='Enter BIOS?' && systemctl --firmware-setup"
    },

    "custom/suspend": {
      "format": " ï“® ",
      "tooltip": false,
      "on-click": "yad --text='Suspend?' && (hyprlock & sleep 1; systemctl suspend)"
    },
    "custom/launcher": {
      "format": " îڑڈ ",
      "tooltip": false,
      "on-click": "rofi -show drun -theme ~/.config/rofi/config.rasi"
    },
    "custom/divider": {
      "format": "|",
      "tooltip": "flase"
    },

    "custom/power-left-end": {
      "format": " ",
      "tooltip": false,
    },
    "group/power": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 600,
        "transition-left-to-right": false,
      },
      "modules": [
        "custom/shutdown",
        "custom/launcher",
        "custom/divider",
        "custom/suspend",
        "custom/divider",
        "custom/logout",
        "custom/divider",
        "custom/reboot",
        "custom/divider",
      ]
    },
	  "backlight": {
		    "tooltip": false,
		    "format": "َ°ƒ‍  {}%",
		     "interval":1,
        "on-scroll-up": "brightnessctl set +2%",
		    "on-scroll-down": "brightnessctl set 2%-"
	}
}

// vim: ft=jsonc
